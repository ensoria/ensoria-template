TESTING_VAR=testing_value
HTTP_PORT=8080
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=ensoria
# Read replica (optional — omit if not using a read replica)
# DB_READ_HOST=replica-host
# DB_READ_PORT=5432
# DB_READ_USER=readonly_user
# DB_READ_PASSWORD=secret
CACHE_HOST=localhost
CACHE_PORT=6379
CACHE_USER=redis
CACHE_PASSWORD=secret
CACHE_TLS=false
LOG_LEVEL=debug
# Container registry (used by `encli build --image` / push; tag defaults to commit ID at push time)
CONTAINER_REGISTRY_LOCAL_IMAGE_NAME=app_name1
CONTAINER_REGISTRY_URI=000000000000.dkr.ecr.ap-northeast-1.amazonaws.com/app_name1
