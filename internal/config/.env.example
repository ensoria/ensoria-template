TESTING_VAR=testing_value
HTTP_PORT=8080
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=ensoria
# Read replica (optional — omit if not using a read replica)
# DB_READ_HOST=replica-host
# DB_READ_PORT=5432
# DB_READ_USER=readonly_user
# DB_READ_PASSWORD=secret
CACHE_HOST=localhost
CACHE_PORT=6379
CACHE_USER=redis
CACHE_PASSWORD=secret
CACHE_TLS=false
LOG_LEVEL=debug
# Container registry (used by `encli build image`; tag defaults to commit ID at push time).
# One pair per build target: server / scheduler / cli / <custom cmd name>.
# Key format: CONTAINER_REGISTRY_<TARGET>_LOCAL_IMAGE_NAME and CONTAINER_REGISTRY_<TARGET>_URI
CONTAINER_REGISTRY_SERVER_LOCAL_IMAGE_NAME=app_name1-server
CONTAINER_REGISTRY_SERVER_URI=000000000000.dkr.ecr.ap-northeast-1.amazonaws.com/app_name1-server
CONTAINER_REGISTRY_SCHEDULER_LOCAL_IMAGE_NAME=app_name1-scheduler
CONTAINER_REGISTRY_SCHEDULER_URI=000000000000.dkr.ecr.ap-northeast-1.amazonaws.com/app_name1-scheduler
CONTAINER_REGISTRY_CLI_LOCAL_IMAGE_NAME=app_name1-cli
CONTAINER_REGISTRY_CLI_URI=000000000000.dkr.ecr.ap-northeast-1.amazonaws.com/app_name1-cli
